{
  "name": "openapi-graft",
  "version": "0.1.0",
  "description": "OpenAPI SDK generator with AST-level 3-way merge for preserved custom code, plus MCP server scaffolding",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "openapi-graft": "dist/index.js",
    "graft": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "openapi",
    "sdk",
    "generator",
    "mcp",
    "ast",
    "merge",
    "cli",
    "code-generation",
    "tree-sitter"
  ],
  "author": "Graft Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chihebnabil/openapi-graft.git"
  },
  "homepage": "https://github.com/chihebnabil/openapi-graft#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.5.0",
    "js-yaml": "^4.1.0",
    "@apidevtools/swagger-parser": "^10.1.0",
    "openapi-types": "^12.1.3",
    "handlebars": "^4.7.8",
    "glob": "^10.4.5",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "zod": "^3.23.8",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.21.2",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-go": "^0.21.2",
    "tree-sitter-java": "^0.21.0",
    "tree-sitter-rust": "^0.21.0",
    "fs-extra": "^11.2.0",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/fs-extra": "^11.0.4",
    "@types/semver": "^7.5.8",
    "typescript": "^5.5.4",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.2.4",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3"
  }
}
